<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="RelaxPro" targetNamespace="http://relaxpro.crm/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.1">
  <process id="booking_process" name="Запись клиента на массаж" isExecutable="false">
    <startEvent id="start" name="Клиент хочет записаться">
      <outgoing>sf1</outgoing>
    </startEvent>
    <userTask id="task_login" name="Авторизация в системе">
      <incoming>sf1</incoming>
      <outgoing>sf2</outgoing>
    </userTask>
    <userTask id="task_view" name="Просмотр услуг и специалистов">
      <incoming>sf2</incoming>
      <outgoing>sf3</outgoing>
    </userTask>
    <userTask id="task_choose" name="Выбор услуги, специалиста и времени">
      <incoming>sf3</incoming>
      <outgoing>sf4</outgoing>
    </userTask>
    <userTask id="task_book" name="Отправка заявки на запись">
      <incoming>sf4</incoming>
      <outgoing>sf5</outgoing>
    </userTask>
    <serviceTask id="task_check" name="Проверка заявки">
      <incoming>sf5</incoming>
      <outgoing>sf6</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_available" name="Заявка корректна?">
      <incoming>sf6</incoming>
      <outgoing>sf7</outgoing>
      <outgoing>sf8</outgoing>
    </exclusiveGateway>
    <userTask id="task_rebook" name="Редактирование заявки">
      <incoming>sf8</incoming>
      <outgoing>sf9</outgoing>
    </userTask>
    <serviceTask id="task_create" name="Создание записи в системе">
      <incoming>sf7</incoming>
      <outgoing>sf10</outgoing>
    </serviceTask>
    <serviceTask id="task_notify" name="Уведомление массажиста о записи">
      <incoming>sf10</incoming>
      <outgoing>sf11</outgoing>
    </serviceTask>
    <userTask id="task_confirm" name="Подтверждение записи массажистом">
      <incoming>sf11</incoming>
      <outgoing>sf12</outgoing>
    </userTask>
    <exclusiveGateway id="gw_confirm" name="Запись подтверждена?">
      <incoming>sf12</incoming>
      <outgoing>sf13</outgoing>
      <outgoing>sf14</outgoing>
    </exclusiveGateway>
    <serviceTask id="task_reject" name="Уведомление клиента об отказе">
      <incoming>sf14</incoming>
      <outgoing>sf15</outgoing>
    </serviceTask>
    <serviceTask id="task_approve" name="Уведомление клиента о подтверждении">
      <incoming>sf13</incoming>
      <outgoing>sf16</outgoing>
    </serviceTask>
    <exclusiveGateway id="gw_cancel" name="Клиент отменяет запись?">
      <incoming>sf16</incoming>
      <outgoing>sf17</outgoing>
      <outgoing>sf18</outgoing>
    </exclusiveGateway>
    <userTask id="task_cancel" name="Отмена записи клиентом">
      <incoming>sf17</incoming>
      <outgoing>sf19</outgoing>
    </userTask>
    <serviceTask id="task_delete" name="Удаление записи из системы">
      <incoming>sf19</incoming>
      <outgoing>sf20</outgoing>
    </serviceTask>
    <userTask id="task_session" name="Проведение сеанса массажа">
      <incoming>sf18</incoming>
      <outgoing>sf21</outgoing>
    </userTask>
    <exclusiveGateway id="gw_end" name="">
      <incoming>sf20</incoming>
      <incoming>sf21</incoming>
      <outgoing>sf22</outgoing>
    </exclusiveGateway>
    <endEvent id="end" name="Процесс завершён">
      <incoming>sf22</incoming>
    </endEvent>
    <endEvent id="end_reject" name="Запись отклонена">
      <incoming>sf15</incoming>
    </endEvent>
    <sequenceFlow id="sf1" sourceRef="start" targetRef="task_login" />
    <sequenceFlow id="sf2" sourceRef="task_login" targetRef="task_view" />
    <sequenceFlow id="sf3" sourceRef="task_view" targetRef="task_choose" />
    <sequenceFlow id="sf4" sourceRef="task_choose" targetRef="task_book" />
    <sequenceFlow id="sf5" sourceRef="task_book" targetRef="task_check" />
    <sequenceFlow id="sf6" sourceRef="task_check" targetRef="gw_available" />
    <sequenceFlow id="sf7" name="Да" sourceRef="gw_available" targetRef="task_create" />
    <sequenceFlow id="sf8" name="Нет" sourceRef="gw_available" targetRef="task_rebook" />
    <sequenceFlow id="sf9" sourceRef="task_rebook" targetRef="task_check" />
    <sequenceFlow id="sf10" sourceRef="task_create" targetRef="task_notify" />
    <sequenceFlow id="sf11" sourceRef="task_notify" targetRef="task_confirm" />
    <sequenceFlow id="sf12" sourceRef="task_confirm" targetRef="gw_confirm" />
    <sequenceFlow id="sf13" name="Да" sourceRef="gw_confirm" targetRef="task_approve" />
    <sequenceFlow id="sf14" name="Нет" sourceRef="gw_confirm" targetRef="task_reject" />
    <sequenceFlow id="sf15" sourceRef="task_reject" targetRef="end_reject" />
    <sequenceFlow id="sf16" sourceRef="task_approve" targetRef="gw_cancel" />
    <sequenceFlow id="sf17" name="Да" sourceRef="gw_cancel" targetRef="task_cancel" />
    <sequenceFlow id="sf18" name="Нет" sourceRef="gw_cancel" targetRef="task_session" />
    <sequenceFlow id="sf19" sourceRef="task_cancel" targetRef="task_delete" />
    <sequenceFlow id="sf20" sourceRef="task_delete" targetRef="gw_end" />
    <sequenceFlow id="sf21" sourceRef="task_session" targetRef="gw_end" />
    <sequenceFlow id="sf22" sourceRef="gw_end" targetRef="end" />
  </process>
  <bpmndi:BPMNDiagram id="diagram">
    <bpmndi:BPMNPlane id="plane" bpmnElement="booking_process">
      <bpmndi:BPMNShape id="s_start" bpmnElement="start">
        <dc:Bounds x="170" y="122" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="155" y="165" width="68" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_login" bpmnElement="task_login">
