      <bpmndi:BPMNShape id="s_confirm" bpmnElement="task_confirm">
        <dc:Bounds x="1690" y="100" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_gw_confirm" bpmnElement="gw_confirm" isMarkerVisible="true">
        <dc:Bounds x="1890" y="115" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1875" y="77.5" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_reject" bpmnElement="task_reject">
        <dc:Bounds x="1860" y="240" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_approve" bpmnElement="task_approve">
        <dc:Bounds x="1990" y="100" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_gw_cancel" bpmnElement="gw_cancel" isMarkerVisible="true">
        <dc:Bounds x="2190" y="115" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2171" y="77.5" width="87" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_cancel" bpmnElement="task_cancel">
        <dc:Bounds x="2160" y="240" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_delete" bpmnElement="task_delete">
        <dc:Bounds x="2360" y="240" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_session" bpmnElement="task_session">
        <dc:Bounds x="2290" y="100" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_end_reject" bpmnElement="end_reject">
        <dc:Bounds x="2062" y="262" width="36" height="36" />
