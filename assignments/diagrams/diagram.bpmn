          <dc:Bounds x="2054" y="305" width="53" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_gw_end" bpmnElement="gw_end" isMarkerVisible="true">
        <dc:Bounds x="2515" y="115" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s_end" bpmnElement="end">
